PORT=8080
API_VERSION=v1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@xxx.railway.app:5432/railway

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:password@xxx.railway.app:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-refresh-secret-in-production-min-32-chars

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOW_ORIGINS=*

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Callback is version-free — register this URL once in Google Cloud Console,
# never needs updating even when API_VERSION changes.
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.up.railway.app/auth/google/callback

# ── Email OTP (Resend) ────────────────────────────────────────────────────────
# Railway blocks SMTP (port 587) — use Resend HTTP API instead.
# Sign up free at resend.com, verify your domain, copy the API key.
# Use onboarding@resend.dev as SMTP_FROM for testing (sends to your email only).
# Leave both blank to skip sending and print OTPs to server logs (local dev).
SMTP_FROM=GrowthMind App <onboarding@resend.dev>
SMTP_PASSWORD=re_your_resend_api_key_here
